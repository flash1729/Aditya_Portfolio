---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Now from "../components/Now.astro";

// Content for sections
const experiences = [
    {
        company: "The C++ Alliance",
        role: "student fellow | remote",
        duration: "present",
        desc: "working on clang's diagnostics, making the compiler catch more of what it currently lets through silently.",
        link: "https://cppalliance.org",
        logo: "C++",
    },
    {
        company: "OneBusAway iOS",
        role: "open source contributor | remote",
        duration: "jan 2024 - present",
        desc: "added persistent bookmark storage, reviewed PRs, and helped tidy up the contributor onboarding.",
        link: "https://github.com/OneBusAway/onebusaway-ios",
        logo: "/logos/oba_logo.png",
    },
];

const projects = [
    {
        title: "Lambda Calculus Interpreter",
        role: "swift, swiftui, c++",
        duration: "wwdc '25 winner",
        desc: "a lambda calculus interpreter built around a recursive descent parser, with error messages that actually tell you what went wrong.",
        logo: "λ",
        link: "https://github.com/flash1729/Lambda-Learner",
        badge: "🏆 wwdc winner",
    },
    {
        title: "AI Studio Code Uploader",
        role: "javascript, chrome extension",
        duration: "chrome extension",
        desc: "auto-renames code files to .txt on upload, so you can drop source straight into google ai studio without renaming everything by hand.",
        logo: "📤",
        link: "https://github.com/flash1729/ai-studio-code-uploader",
    },
    {
        title: "CodeSathi",
        role: "react, node.js, socket.io, mongodb",
        duration: "real-time collaborative code editor",
        desc: "a collaborative code editor with low-latency editing, a mongodb-backed file system, and gemini wired in for help while you code.",
        logo: "⚡",
        link: "#",
    },
];

const skills = [
    "swift",
    "c++",
    "python",
    "typescript",
    "swiftui",
    "react",
    "node.js",
    "docker",
    "xcode",
    "git",
    "system design",
    "compilers",
];
---

<Layout title="Aditya Medhane">
    <Hero />

    <Now />

    <!-- About Section -->
    <section class="about">
        <h2>about</h2>
        <p class="about-text">
            compilers have always fascinated me. not just what they produce, but
            how they work inside. there's something genuinely interesting about a
            piece of software that understands other software.<br /><br />
            i'm a cs undergrad at <a
                href="https://www.iiitm.ac.in/"
                target="_blank"
                rel="noopener">iiitm gwalior</a
            >. i won the wwdc swift student challenge in 2025 for a lambda calculus
            interpreter, and right now i'm deep in parsers, type systems, and how
            clang talks to us through its diagnostics. on the side i build ios apps
            and contribute to open source.
        </p>
    </section>

    <!-- Experience Section -->
    <section class="experience">
        <h2>cool places i worked at</h2>
        {
            experiences.map((exp) => (
                <a
                    href={exp.link}
                    target="_blank"
                    rel="noopener"
                    class="work-card"
                >
                    <div class="work-logo logo-bare">
                        {exp.logo.includes(".") ? (
                            <img
                                src={exp.logo}
                                alt={exp.company}
                                class="company-logo-img"
                            />
                        ) : (
                            exp.logo
                        )}
                    </div>
                    <div class="work-info">
                        <h3>{exp.company}</h3>
                        <p class="work-duration">{exp.duration}</p>
                        <p class="work-role">{exp.role}</p>
                        <p class="work-desc">{exp.desc}</p>
                    </div>
                </a>
            ))
        }
    </section>

    <!-- Projects Section -->
    <section class="projects">
        <h2>things i've built</h2>
        {
            projects.map((proj) => {
                const isLink = proj.link && proj.link !== "#";
                const Tag = isLink ? "a" : "div";
                return (
                <Tag {...(isLink ? { href: proj.link } : {})} class="work-card project-card">
                    <div class="work-logo">
                        {proj.logo.includes(".") ? (
                            <img
                                src={proj.logo}
                                alt={proj.title}
                                class="company-logo-img"
                            />
                        ) : (
                            proj.logo
                        )}
                    </div>
                    <div class="work-info">
                        <h3>{proj.title}</h3>
                        <p class="work-duration">{proj.duration}</p>
                        <p class="work-role">{proj.role}</p>
                        <p class="work-desc">{proj.desc}</p>
                    </div>
                    {proj.badge && (
                        <span class="project-badge">{proj.badge}</span>
                    )}
                </Tag>
                );
            })
        }
    </section>

    <!-- Education Section -->
    <section class="education">
        <h2>education</h2>
        <a
            href="https://www.iiitm.ac.in/"
            target="_blank"
            rel="noopener"
            class="work-card"
        >
            <div class="work-logo">
                <img
                    src="/logos/iiitm_logo.jpg"
                    alt="IIITM Gwalior"
                    class="company-logo-img"
                    onerror="this.style.display='none'; this.parentElement.innerText='🎓'"
                />
            </div>
            <div class="work-info">
                <h3>IIITM Gwalior</h3>
                <p class="work-duration">2023 - 2027</p>
                <p class="work-role">b.tech in computer science engineering</p>
                <p class="work-desc">
                    cgpa: 8/10 • data structures, algorithms, os, compilers,
                    distributed systems
                </p>
            </div>
        </a>
    </section>

    <!-- Leadership Section -->
    <section class="leadership">
        <h2>leadership</h2>
        <div class="work-card">
            <div class="work-logo">
                <img
                    src="/logos/gdg_logo.png"
                    alt="GDG"
                    class="company-logo-img"
                    onerror="this.style.display='none'; this.parentElement.innerText='G'"
                />
            </div>
            <div class="work-info">
                <h3>Google Developer Group, IIITM</h3>
                <p class="work-duration">sep 2025 - present</p>
                <p class="work-role">ios and open source lead</p>
                <p class="work-desc">
                    i run the ios workshops and help students get into open
                    source. mentored 50+ so far.
                </p>
            </div>
        </div>
        <div class="work-card">
            <div class="work-logo">
                <img
                    src="/logos/ecell_logo.jpeg"
                    alt="E-Cell"
                    class="company-logo-img"
                    onerror="this.style.display='none'; this.parentElement.innerText='E'"
                />
            </div>
            <div class="work-info">
                <h3>E-Cell IIITM</h3>
                <p class="work-duration">dec 2024 - present</p>
                <p class="work-role">operations executive</p>
                <p class="work-desc">
                    handling logistics and tech ops for 300-person hackathons.
                </p>
            </div>
        </div>
    </section>

    <!-- Awards Section -->
    <section class="awards">
        <h2>honors & awards</h2>
        <div class="award-card">
            <div
                class="work-logo logo-bare"
                style="width: 60px; height: 60px; margin-right: 16px;"
            >
                <img
                    src="/logos/ssc_logo.png"
                    alt="SSC Winner"
                    class="company-logo-img"
                    onerror="this.style.display='none'; this.parentElement.innerText='🍎'"
                />
            </div>
            <div class="award-info">
                <h3>WWDC Swift Student Challenge Winner</h3>
                <p>
                    selected as one of 350 winners globally (top &lt;5% of
                    applicants)
                </p>
                <span class="award-year">2025</span>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section class="skills">
        <h2>skills</h2>
        <div class="skills-grid">
            {skills.map((skill) => <span class="skill-tag">{skill}</span>)}
        </div>
    </section>

    <!-- Contact -->
    <section class="contact">
        <p>
            say hello on <a
                href="https://x.com/Adi_flash1729"
                target="_blank"
                rel="noopener">𝕏</a
            >
        </p>
    </section>
</Layout>

<script>
    // Scroll Animation
    const observerOptions = {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).style.opacity = "1";
                (entry.target as HTMLElement).style.transform = "translateY(0)";
            }
        });
    }, observerOptions);

    document
        .querySelectorAll("section, .work-card, .award-card")
        .forEach((el) => {
            const element = el as HTMLElement;
            element.style.opacity = "0";
            element.style.transform = "translateY(20px)";
            element.style.transition = `opacity 0.6s ease, transform 0.6s ease`;
            observer.observe(element);
        });
</script>
