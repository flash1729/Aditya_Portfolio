---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
    d.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
---

<Layout title={`${post.data.title} | Aditya Medhane`} description={post.data.description}>
    <a href="/blog" class="back-link">← blog</a>

    <article class="post">
        <header class="post-header">
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
            <h1>{post.data.title}</h1>
            {
                post.data.tags && (
                    <div class="post-tags">
                        {post.data.tags.map((t) => (
                            <span class="post-tag">{t}</span>
                        ))}
                    </div>
                )
            }
        </header>

        <div class="prose">
            <Content />
        </div>
    </article>

    <footer class="post-footer">
        <p>
            found a mistake or want to talk compilers? say hi on <a
                href="https://x.com/Adi_flash1729"
                target="_blank"
                rel="noopener">𝕏</a
            >.
        </p>
        <a href="/blog" class="back-link">← back to blog</a>
    </footer>
</Layout>

<style>
    .back-link {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--text-muted);
        margin-bottom: 40px;
    }

    .back-link:hover {
        color: var(--accent);
    }

    .post-header {
        margin-bottom: 40px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border-color);
    }

    .post-header time {
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--accent);
    }

    .post-header h1 {
        font-size: 2.4rem;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin: 12px 0 16px;
    }

    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .post-tag {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-secondary);
        padding: 3px 10px;
        border: 1px solid var(--border-color);
        border-radius: 100px;
    }

    .post-footer {
        margin-top: 64px;
        padding-top: 32px;
        border-top: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .post-footer p {
        color: var(--text-secondary);
        font-size: 0.95rem;
    }

    .post-footer a[target] {
        color: var(--accent);
        font-weight: 600;
    }

    @media (max-width: 640px) {
        .post-header h1 {
            font-size: 1.9rem;
        }
    }
</style>
