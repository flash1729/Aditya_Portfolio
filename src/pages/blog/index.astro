---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
    d.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });
---

<Layout title="Blog | Aditya Medhane">
    <section class="blog-header">
        <h1>blog</h1>
        <p class="blog-intro">
            notes from learning compilers in public. mostly LLVM and Clang, mostly
            from the perspective of someone still figuring it out.
        </p>
    </section>

    <section class="blog-posts">
        {
            posts.map((post) => (
                <a href={`/blog/${post.id}`} class="blog-post-link">
                    <article class="blog-post">
                        <time datetime={post.data.date.toISOString()}>
                            {fmt(post.data.date)}
                        </time>
                        <h2>{post.data.title}</h2>
                        <p class="blog-excerpt">{post.data.description}</p>
                        {post.data.tags && (
                            <div class="post-tags">
                                {post.data.tags.map((t) => (
                                    <span class="post-tag">{t}</span>
                                ))}
                            </div>
                        )}
                    </article>
                </a>
            ))
        }
    </section>
</Layout>

<style>
    .blog-header {
        margin-bottom: 48px;
    }

    .blog-header h1 {
        font-size: 2.25rem;
        font-weight: 800;
        margin-bottom: 12px;
        letter-spacing: -0.03em;
    }

    .blog-intro {
        color: var(--text-secondary);
        font-size: 1.05rem;
        max-width: 34rem;
        line-height: 1.6;
    }

    .blog-posts {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .blog-post-link {
        display: block;
    }

    .blog-post {
        padding: 24px;
        border: 1px solid var(--border-color);
        border-radius: 16px;
        background: var(--card-bg);
        transition: var(--transition);
    }

    .blog-post-link:hover .blog-post {
        border-color: var(--accent);
        background: var(--card-hover);
        transform: translateY(-2px);
    }

    .blog-post time {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--accent);
        letter-spacing: 0.02em;
    }

    .blog-post h2 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 8px 0 8px;
        letter-spacing: -0.01em;
    }

    .blog-excerpt {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 16px;
    }

    .post-tag {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-secondary);
        padding: 3px 10px;
        border: 1px solid var(--border-color);
        border-radius: 100px;
    }
</style>
