---
---

<section class="hero">
    <div class="hero-content">
        <h1>hi, aditya here</h1>
        <p class="tagline">
            i'm into compilers, the software that reads other software. these days
            i'm contributing to <span class="tag-accent">LLVM</span> and <span
                class="tag-accent">Clang</span
            >.
        </p>
    </div>

    <div class="hero-card" aria-hidden="true">
        <div class="card-bar">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
            <span class="card-title">aditya.cpp</span>
        </div>
        <pre class="card-body"><code><span class="c-com">// ∞ harry potter rereads</span>
<span class="c-key">struct</span> <span class="c-fn">aditya</span> &#123;
  works_on = <span class="c-str">"clang diagnostics"</span>;
  plays    = <span class="c-str">"tabla, football"</span>;
  wants    = <span class="c-str">"friends worldwide"</span>;
&#125;;<span class="cursor"></span></code></pre>
    </div>
</section>

<style>
    .hero {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 88px;
        gap: 48px;
    }

    .hero-content {
        flex: 1;
        min-width: 0;
    }

    .hero-content h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 14px;
        letter-spacing: -0.035em;
        line-height: 1.05;
    }

    .tagline {
        font-size: 1.05rem;
        color: var(--text-secondary);
        max-width: 30rem;
        line-height: 1.65;
    }

    .tag-accent {
        font-family: var(--font-mono);
        font-size: 0.92em;
        color: var(--text-primary);
        font-weight: 600;
    }

    /* Terminal-style code card */
    .hero-card {
        flex-shrink: 0;
        width: 320px;
        max-width: 100%;
        border: 1px solid var(--border-color);
        border-radius: 14px;
        background: #0d0d11;
        overflow: hidden;
        box-shadow:
            0 24px 60px -28px var(--accent-glow),
            0 12px 40px -20px rgba(0, 0, 0, 0.6);
    }

    .card-bar {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 10px 14px;
        background: #141419;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
    }
    .dot-r {
        background: #ff5f56;
    }
    .dot-y {
        background: #ffbd2e;
    }
    .dot-g {
        background: #27c93f;
    }

    .card-title {
        margin-left: 8px;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: #6b6b76;
    }

    .card-body {
        margin: 0;
        padding: 18px 18px 20px;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.7;
        color: #e4e4ea;
        overflow-x: auto;
    }

    .c-com {
        color: #5a5a66;
    }
    .c-key {
        color: #5fd0dd;
        font-weight: 600;
    }
    .c-fn {
        color: #7ee0c0;
    }
    .c-str {
        color: #e0b08a;
    }

    .cursor {
        display: inline-block;
        width: 8px;
        height: 1em;
        background: #5fd0dd;
        margin-left: 2px;
        vertical-align: text-bottom;
        animation: blink 1.1s steps(1) infinite;
    }

    @keyframes blink {
        0%,
        50% {
            opacity: 1;
        }
        50.01%,
        100% {
            opacity: 0;
        }
    }

    @media (max-width: 720px) {
        .hero {
            flex-direction: column;
            align-items: flex-start;
            gap: 36px;
            margin-bottom: 64px;
        }

        .hero-content h1 {
            font-size: 2.3rem;
        }

        .hero-card {
            width: 100%;
        }
    }
</style>
